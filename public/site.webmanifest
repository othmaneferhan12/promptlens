{
  "name": "Image To Prompt",
  "short_name": "ImgToPrompt",
  "description": "Free AI tool to convert any image into a detailed prompt for Midjourney, DALL-E, Stable Diffusion and more.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0F0F1A",
