# PromptLens Environment Variables
# Copy this to .env and fill in your values

# Required: Your Anthropic API key (server-side only — never expose to client)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Required: Shared secret between frontend and API (blocks direct API abuse)
# Must be set in Vercel environment variables too
APP_SECRET=your-secret-here
VITE_APP_SECRET=your-secret-here

# Optional: Your deployed Vercel domain (used for CORS whitelist)
# Leave blank during local development
VERCEL_URL=your-app.vercel.app
